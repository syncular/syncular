{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Syncular Query",
  "scopeName": "source.syql",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#declarations" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-dash.syql", "match": "--.*$" },
        { "name": "comment.block.syql", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "imports": {
      "begin": "\\b(import)\\b",
      "beginCaptures": { "1": { "name": "keyword.control.import.syql" } },
      "end": ";",
      "endCaptures": { "0": { "name": "punctuation.terminator.syql" } },
      "patterns": [
        { "include": "#comments" },
        { "match": "\\b(as|from)\\b", "name": "keyword.control.import.syql" },
        { "match": "\"(?:\\\\.|[^\"\\\\])*\"", "name": "string.quoted.double.import-path.syql" },
        { "match": "[a-z][A-Za-z0-9]*", "name": "entity.name.function.predicate.syql" }
      ]
    },
    "declarations": {
      "begin": "\\b(query|predicate)\\s+([a-z][A-Za-z0-9]*)",
      "beginCaptures": {
        "1": { "name": "keyword.control.declaration.syql" },
        "2": { "name": "entity.name.function.syql" }
      },
      "end": "(?<=\\})",
      "patterns": [
        { "include": "#comments" },
        { "include": "#types" },
        { "include": "#container-keywords" },
        { "include": "#embedded-nodes" },
        { "include": "#binds" },
        { "include": "#atomic-sql" },
        { "include": "source.sql" }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(string|integer|float|boolean|json|bytes|blob_ref|crdt|null)\\b",
          "name": "storage.type.syql"
        },
        { "match": "\\b(switch)\\b", "name": "storage.type.switch.syql" },
        { "match": "\\?", "name": "keyword.operator.optional.syql" },
        { "match": "\\|", "name": "keyword.operator.union.syql" }
      ]
    },
    "container-keywords": {
      "patterns": [
        {
          "match": "\\b(sql|sort|default|page|max|identity|by)\\b",
          "name": "keyword.other.member.syql"
        },
        { "match": "\\b\\d+\\b", "name": "constant.numeric.syql" }
      ]
    },
    "embedded-nodes": {
      "patterns": [
        {
          "match": "@(scope|cover)\\b",
          "name": "support.function.reactive.syql"
        },
        {
          "match": "@([a-z][A-Za-z0-9]*)",
          "captures": { "1": { "name": "entity.name.function.predicate.syql" } }
        },
        { "match": "\\bwhen\\b", "name": "keyword.control.conditional.syql" }
      ]
    },
    "binds": {
      "patterns": [
        { "match": ":[A-Za-z_][A-Za-z0-9_]*", "name": "variable.parameter.bind.syql" }
      ]
    },
    "atomic-sql": {
      "patterns": [
        {
          "name": "string.quoted.single.sql",
          "begin": "'",
          "end": "'",
          "patterns": [{ "match": "''", "name": "constant.character.escape.sql" }]
        },
        {
          "name": "string.quoted.double.identifier.sql",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "match": "\"\"", "name": "constant.character.escape.sql" }]
        },
        { "match": "[xX]'(?:[0-9A-Fa-f]{2})*'", "name": "constant.numeric.blob.sql" }
      ]
    }
  }
}
