{
  "name": "@syncular/tests-expo-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "tsgo": "tsgo --noEmit",
    "start:dev-client": "expo start --dev-client --localhost",
    "ios:build": "expo run:ios --no-bundler --no-build-cache --device \"${IOS_SIMULATOR_DEVICE:-iPhone 16}\"",
    "maestro:test": "maestro test ./maestro"
  },
  "dependencies": {
    "expo": "~55.0.11",
    "expo-dev-client": "^55.0.22",
    "react": "19.2.4",
    "react-native": "0.84.1"
  },
  "devDependencies": {
    "@syncular/dialect-expo-sqlite": "workspace:*",
    "@types/react": "~19.2.14",
    "expo-sqlite": "^55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "^55.0.13",
    "expo-updates": "^55.0.18",
    "kysely": "*",
    "typescript": "~6.0.2"
  }
}
