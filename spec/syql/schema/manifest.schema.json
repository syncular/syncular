{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syncular.dev/schema/syql/manifest-v1.json",
  "title": "SYQL conformance manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "language",
    "revision",
    "fixtureSchemaRevision",
    "sqliteProfile",
    "families"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "language": { "const": "SYQL" },
    "revision": { "const": 1 },
    "fixtureSchemaRevision": { "const": 3 },
    "sqliteProfile": { "const": "3.46.0" },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path"],
        "properties": {
          "kind": {
            "enum": ["lexical", "syntax", "semantic", "lowering", "formatter", "emitter"]
          },
          "path": {
            "type": "string",
            "pattern": "^v1/(lexical|syntax|semantic|lowering|formatter|emitter)/[A-Za-z0-9._/-]+\\.json$"
          }
        }
      }
    }
  }
}
