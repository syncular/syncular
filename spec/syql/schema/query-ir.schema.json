{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syncular.dev/schema/syql/query-ir-v3.json",
  "title": "SYQL revision-1 QueryIR v3",
  "description": "Normative target-neutral compiler boundary emitted for revision-1 SYQL queries.",
  "type": "object",
  "additionalProperties": false,
  "required": ["queryIrVersion", "queries"],
  "properties": {
    "queryIrVersion": { "const": 3 },
    "queries": {
      "type": "array",
      "items": { "$ref": "#/$defs/query" }
    }
  },
  "$defs": {
    "identifier": { "type": "string", "minLength": 1 },
    "valueType": {
      "enum": ["string", "integer", "float", "boolean", "json", "bytes", "blob_ref", "crdt"]
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name", "file", "sourceSql", "sql", "positionalSql", "params",
        "columns", "tables", "reactive", "syql"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "file": { "type": "string" },
        "sourceSql": { "type": "string" },
        "sql": { "type": "string" },
        "positionalSql": { "type": "string" },
        "params": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "langName", "type"],
            "properties": {
              "name": { "$ref": "#/$defs/identifier" },
              "langName": { "$ref": "#/$defs/identifier" },
              "type": { "$ref": "#/$defs/valueType" }
            }
          }
        },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/column" }
        },
        "tables": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "reactive": { "$ref": "#/$defs/reactive" },
        "syql": { "$ref": "#/$defs/syql" }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "langName", "type", "nullable", "fidelity"],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "langName": { "$ref": "#/$defs/identifier" },
        "type": { "$ref": "#/$defs/valueType" },
        "nullable": { "type": "boolean" },
        "fidelity": { "enum": ["exact", "fallback"] },
        "origin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "column"],
          "properties": {
            "table": { "$ref": "#/$defs/identifier" },
            "column": { "$ref": "#/$defs/identifier" }
          }
        }
      }
    },
    "reactive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependencies", "coverage"],
      "properties": {
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["table", "scopes"],
            "properties": {
              "table": { "$ref": "#/$defs/identifier" },
              "scopes": {
                "type": "array",
                "items": { "$ref": "#/$defs/scope" }
              }
            }
          }
        },
        "coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["table", "variable", "units", "fixedScopes"],
            "properties": {
              "table": { "$ref": "#/$defs/identifier" },
              "variable": { "$ref": "#/$defs/identifier" },
              "units": { "type": "array", "items": { "$ref": "#/$defs/identifier" } },
              "fixedScopes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["variable", "params"],
                  "properties": {
                    "variable": { "$ref": "#/$defs/identifier" },
                    "params": { "type": "array", "items": { "$ref": "#/$defs/identifier" } }
                  }
                }
              }
            }
          }
        },
        "rowKey": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/identifier" } }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variable", "pattern", "params"],
      "properties": {
        "variable": { "$ref": "#/$defs/identifier" },
        "pattern": { "type": "string" },
        "params": { "type": "array", "items": { "$ref": "#/$defs/identifier" } }
      }
    },
    "syql": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "inputs", "plan"],
      "properties": {
        "revision": { "const": 1 },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/publicInput" } },
        "plan": { "$ref": "#/$defs/plan" },
        "identity": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/identifier" } }
      }
    },
    "publicInput": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "langName", "type", "nullable", "required"],
          "properties": {
            "kind": { "const": "value" },
            "name": { "$ref": "#/$defs/identifier" },
            "langName": { "$ref": "#/$defs/identifier" },
            "type": { "$ref": "#/$defs/valueType" },
            "nullable": { "type": "boolean" },
            "required": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "langName", "members"],
          "properties": {
            "kind": { "const": "group" },
            "name": { "$ref": "#/$defs/identifier" },
            "langName": { "$ref": "#/$defs/identifier" },
            "members": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "langName", "type", "nullable"],
                "properties": {
                  "name": { "$ref": "#/$defs/identifier" },
                  "langName": { "$ref": "#/$defs/identifier" },
                  "type": { "$ref": "#/$defs/valueType" },
                  "nullable": { "type": "boolean" }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "langName", "default"],
          "properties": {
            "kind": { "const": "switch" },
            "name": { "$ref": "#/$defs/identifier" },
            "langName": { "$ref": "#/$defs/identifier" },
            "default": { "const": false }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "langName", "defaultProfile", "profiles"],
          "properties": {
            "kind": { "const": "sort" },
            "name": { "$ref": "#/$defs/identifier" },
            "langName": { "$ref": "#/$defs/identifier" },
            "defaultProfile": { "$ref": "#/$defs/identifier" },
            "profiles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "langName"],
                "properties": {
                  "name": { "$ref": "#/$defs/identifier" },
                  "langName": { "$ref": "#/$defs/identifier" }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "langName", "defaultSize", "maxSize"],
          "properties": {
            "kind": { "const": "page" },
            "name": { "$ref": "#/$defs/identifier" },
            "langName": { "$ref": "#/$defs/identifier" },
            "defaultSize": { "type": "integer", "minimum": 1 },
            "maxSize": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "activationControls", "conditions", "statements"],
      "properties": {
        "backend": { "enum": ["neutralize", "variants"] },
        "activationControls": { "type": "array", "items": { "$ref": "#/$defs/identifier" } },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["controls"],
            "properties": {
              "controls": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/identifier" } },
              "bind": { "$ref": "#/$defs/identifier" }
            }
          }
        },
        "statements": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/statement" } }
      }
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sql", "positionalSql", "binds"],
      "properties": {
        "sortProfile": { "$ref": "#/$defs/identifier" },
        "activationMask": { "type": "integer", "minimum": 0 },
        "sql": { "type": "string" },
        "positionalSql": { "type": "string" },
        "binds": { "type": "array", "items": { "$ref": "#/$defs/bind" } }
      }
    },
    "bind": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "type", "input"],
          "properties": {
            "kind": { "const": "value" },
            "name": { "$ref": "#/$defs/identifier" },
            "type": { "$ref": "#/$defs/valueType" },
            "input": { "$ref": "#/$defs/identifier" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "type", "input", "member"],
          "properties": {
            "kind": { "const": "group-member" },
            "name": { "$ref": "#/$defs/identifier" },
            "type": { "$ref": "#/$defs/valueType" },
            "input": { "$ref": "#/$defs/identifier" },
            "member": { "$ref": "#/$defs/identifier" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "type", "condition", "controls"],
          "properties": {
            "kind": { "const": "condition-active" },
            "name": { "$ref": "#/$defs/identifier" },
            "type": { "const": "boolean" },
            "condition": { "type": "integer", "minimum": 0 },
            "controls": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/identifier" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "type", "input"],
          "properties": {
            "kind": { "const": "page" },
            "name": { "$ref": "#/$defs/identifier" },
            "type": { "const": "integer" },
            "input": { "$ref": "#/$defs/identifier" }
          }
        }
      ]
    }
  }
}
