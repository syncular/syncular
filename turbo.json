{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.json"],
  "globalPassThroughEnv": [
    "ACTIONS_ID_TOKEN_REQUEST_URL",
    "ACTIONS_ID_TOKEN_REQUEST_TOKEN",
    "SYNCULAR_NPM_TAG",
    "SYNCULAR_PUBLISH_DRY_RUN",
    "npm_config_registry"
  ],
  "tasks": {
    "tsgo": {
      "dependsOn": ["^tsgo"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@syncular/client-javascript-bindings#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../crates/**",
        "../../Cargo.toml",
        "../../Cargo.lock",
        "../../../packages/client/package.json"
      ],
      "outputs": ["dist/**", "src/generated-wasm-bindings.d.ts"]
    },
    "release": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
