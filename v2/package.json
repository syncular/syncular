{
  "name": "syncular-v2",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*", "bench"],
  "scripts": {
    "check": "bun run typecheck && bun run lint && bun test",
    "bench": "bun run --cwd bench bench",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@syncular-v2/typegen": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
