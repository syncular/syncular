# The plugin workspace's own cargo target (kept out of the main rust tree).
/target
# Tauri build-time generated ACL/schema artifacts for the example.
/example/src-tauri/gen
# The React frontend bundle (produced by `bun run build-frontend`).
/example/dist
# Per-package deps linked by `bun install` (example is a workspace member).
/example/node_modules
