---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSyncularGitHubStars, SYNCULAR_GITHUB_URL } from '../utils/github';

const githubStars = await getSyncularGitHubStars();
---

<BaseLayout
  title="Syncular — Local-first sync framework"
  description="Syncular is a type-safe sync framework for local-first apps. A Rust runtime owns SQLite on the client. An immutable commit log carries every change to every peer."
>
  <main class="lp">
    <!-- Nav -->
    <header class="lp-nav">
      <div class="lp-nav-inner">
        <a href="/" class="lp-nav-logo">
          <svg width="18" height="18" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="16" cy="16" r="3" fill="currentColor"/>
          </svg>
          Syncular
        </a>
        <nav class="lp-nav-links">
          <a href="#features">Features</a>
          <a href="#how">How it works</a>
          <a href="#code">Code</a>
          <a href="https://docs.syncular.dev">Docs</a>
        </nav>
        <div class="lp-nav-actions">
          <a href={SYNCULAR_GITHUB_URL} class="lp-btn-ghost" target="_blank" rel="noreferrer">GitHub</a>
          <a href="https://docs.syncular.dev" class="lp-btn-solid">Get started</a>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="lp-hero">
      <div class="lp-dot-grid"></div>
      <div class="lp-grad-fade"></div>
      <div class="lp-hero-inner">
        <div class="lp-hero-content">
          <div class="lp-pill lp-mono">
            <span class="lp-pill-dot"></span>
            <span>v0.x</span>
            <span class="lp-pill-sep">·</span>
            <span>Local-first sync framework</span>
          </div>
          <h1 class="lp-h1">
            Sync, without<br/>
            <span class="lp-h1-muted">the orbit.</span>
          </h1>
          <p class="lp-hero-body">
            Syncular is a type-safe sync framework for local-first apps. A Rust runtime owns SQLite on the client. An immutable commit log carries every change to every peer. Reads are local. Writes are durable.
          </p>
          <div class="lp-cta">
            <a href="https://docs.syncular.dev" class="lp-cta-primary">Get started →</a>
            <a href="#code" class="lp-btn-outline">View code</a>
          </div>
          <div class="lp-meta lp-mono">
            <span>Apache 2.0</span><span>·</span>
            <span>Postgres + SQLite</span><span>·</span>
            <span>React, Solid, Rust</span><span>·</span>
            <span>Self-hosted</span>
          </div>
        </div>

        <div class="lp-orbit-wrap">
          <div class="lp-orbit-dot-grid"></div>
          <div class="lp-orbit-ring"></div>
          <div class="lp-orbit-ring lp-orbit-ring-inner"></div>
          <div class="lp-orbit-core"></div>
          <div class="lp-orbit-dot"></div>
          <div class="lp-orbit-dot lp-orbit-dot-b"></div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="lp-section">
      <div class="lp-section-inner">
        <div class="lp-features-grid">
          <div>
            <div class="lp-kicker lp-mono">§01 — Primitives</div>
            <h2 class="lp-h2">Small surface.<br/><span class="lp-h2-muted">Large guarantees.</span></h2>
          </div>
          <div class="lp-cards">
            <div class="lp-card">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <rect x="3" y="3" width="14" height="14" stroke="currentColor" stroke-width="1" rx="1"/>
                <line x1="3" y1="7" x2="17" y2="7" stroke="currentColor" stroke-width="1"/>
              </svg>
              <div class="lp-card-title">Local-first</div>
              <p class="lp-card-body">Reads hit a Rust-owned SQLite database in under a millisecond. The network is recovery, not the hot path.</p>
            </div>
            <div class="lp-card">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <line x1="4" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1"/>
                <circle cx="4" cy="10" r="2" fill="currentColor"/>
                <circle cx="10" cy="10" r="2" fill="currentColor"/>
                <circle cx="16" cy="10" r="2" fill="currentColor"/>
              </svg>
              <div class="lp-card-title">Commit-log sync</div>
              <p class="lp-card-body">Append-only on the server. Clients fetch what they haven't seen. Causality is preserved by construction.</p>
            </div>
            <div class="lp-card">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <path d="M3 5 L17 5 L10 17 Z" stroke="currentColor" stroke-width="1"/>
              </svg>
              <div class="lp-card-title">Scoped auth</div>
              <p class="lp-card-body">Every change is tagged with key-value scopes. Every pull is filtered by what the actor is allowed to see.</p>
            </div>
            <div class="lp-card">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <path d="M4 6 L16 6 M4 10 L12 10 M4 14 L8 14" stroke="currentColor" stroke-width="1"/>
              </svg>
              <div class="lp-card-title">Typed queries</div>
              <p class="lp-card-body">Kysely on JavaScript. Diesel on Rust. The schema is the contract; the compiler is the auditor.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Code -->
    <section id="code" class="lp-section">
      <div class="lp-section-inner">
        <div class="lp-code-grid">
          <div>
            <div class="lp-kicker lp-mono">§02 — Specimen</div>
            <h2 class="lp-h2">One component.<br/><span class="lp-h2-muted">Nothing to wait for.</span></h2>
            <p class="lp-code-desc">The read hits local SQLite. The mutation writes locally and queues in the outbox. The engine syncs in the background.</p>
          </div>
          <div class="lp-code-block">
            <div class="lp-code-titlebar">
              <div style="display:flex;align-items:center;">
                <div class="lp-code-dots">
                  <span class="lp-code-dot"></span>
                  <span class="lp-code-dot"></span>
                  <span class="lp-code-dot"></span>
                </div>
                <span class="lp-code-filename lp-mono">TaskList.tsx</span>
              </div>
              <span class="lp-code-lang lp-mono">React &middot; TypeScript</span>
            </div>
            <pre class="lp-pre lp-mono"><code><span class="tk-kw">function</span> <span class="tk-fn">TaskList</span>() &#123;
  <span class="tk-kw">const</span> &#123; data: tasks &#125; = <span class="tk-fn">useSyncQuery</span>(&#40;&#40;&#123; selectFrom &#125;&#41; =&gt;
    selectFrom&#40;<span class="tk-str">'tasks'</span>&#41;.selectAll&#40;&#41;.where&#40;<span class="tk-str">'completed'</span>, <span class="tk-str">'='</span>, <span class="tk-num">0</span>&#41;
  &#41;;
  <span class="tk-kw">const</span> m = <span class="tk-fn">useMutations</span>&#40;&#41;;

  <span class="tk-kw">return</span> &#40;
    &lt;<span class="tk-fn">ul</span>&gt;
      &#123;tasks?.map&#40;&#40;task&#41; =&gt; &#40;
        &lt;<span class="tk-fn">li</span> key=&#123;task.id&#125; onClick=&#123;&#40;&#41; =&gt; m.tasks.update&#40;task.id, &#123; completed: <span class="tk-num">1</span> &#125;&#41;&#125;&gt;
          &#123;task.title&#125;
        &lt;/<span class="tk-fn">li</span>&gt;
      &#41;&#41;&#125;
    &lt;/<span class="tk-fn">ul</span>&gt;
  &#41;;
&#125;</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section id="how" class="lp-section">
      <div class="lp-section-inner">
        <div class="lp-flow-header">
          <div class="lp-kicker lp-mono">§03 — Path of a write</div>
          <h2 class="lp-h2">From keystroke to every peer,<br/><span class="lp-h2-muted">in four moves.</span></h2>
        </div>
        <div class="lp-flow-grid">
          <div class="lp-flow-cell">
            <div class="lp-flow-step lp-mono">01 &middot; WRITE</div>
            <div class="lp-flow-title">Local SQLite</div>
            <p class="lp-flow-body">Mutation lands. UI re-renders in the same tick.</p>
          </div>
          <div class="lp-flow-cell">
            <div class="lp-flow-step lp-mono">02 &middot; PUSH</div>
            <div class="lp-flow-title">Outbox flushes</div>
            <p class="lp-flow-body">Rust runtime drains over HTTP. Server validates.</p>
          </div>
          <div class="lp-flow-cell">
            <div class="lp-flow-step lp-mono">03 &middot; LOG</div>
            <div class="lp-flow-title">Commit appended</div>
            <p class="lp-flow-body">Tagged with scopes. Canonical, replayable, durable.</p>
          </div>
          <div class="lp-flow-cell">
            <div class="lp-flow-step lp-mono">04 &middot; PULL</div>
            <div class="lp-flow-title">Peers wake</div>
            <p class="lp-flow-body">WebSocket nudges. Peers pull what&apos;s new.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="lp-cta-section">
      <div class="lp-cta-inner">
        <h2 class="lp-cta-h2">Ready when you are.</h2>
        <p class="lp-cta-sub">Apache 2.0. Self-hosted. Built for teams that take sync seriously.</p>
        <div class="lp-cta-buttons">
          <a href="https://docs.syncular.dev" class="lp-cta-primary lp-mono">npm i @syncular/client</a>
          <a href="https://docs.syncular.dev" class="lp-btn-outline">Read the docs &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="lp-footer">
      <div class="lp-footer-inner">
        <div class="lp-footer-logo">
          <svg width="14" height="14" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="16" cy="16" r="3" fill="currentColor"/>
          </svg>
          Syncular
        </div>
        <span class="lp-mono">&copy; 2026 &middot; Apache 2.0</span>
      </div>
    </footer>
  </main>
</BaseLayout>
