---
import BlogHeader from '../../components/BlogHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../utils/github';
import { getAllBlogPosts } from '../../utils/blog';

const posts = getAllBlogPosts();
---

<BaseLayout
  title="Syncular Blog"
  description="Engineering notes on offline-first architecture, sync, and production learnings."
>
  <BlogHeader />
  <main class="apex-blog-index">
    <header class="apex-blog-index-header animate-fade-up">
      <p class="apex-blog-kicker">Engineering Journal</p>
      <h1 class="apex-blog-title">Blog</h1>
      <p class="apex-blog-subtitle">
        Long-form writeups on offline-first architecture, sync tradeoffs, and practical lessons from building
        Syncular.
      </p>
    </header>

    {posts.length === 0 ? (
      <div class="apex-post-empty">No posts yet. Check back soon.</div>
    ) : (
      <section class="apex-post-list">
        {posts.map((post, index) => (
          <a class="apex-post-link" href={`/blog/${post.slug}`} style={`--apex-delay: ${index * 80}ms`}>
            <div class="apex-post-meta-row">
              <time class="apex-post-meta-time" datetime={new Date(post.date).toISOString()}>
                {formatDate(post.date)}
              </time>
              {post.author ? (
                <>
                  <span class="apex-post-meta-dot">&middot;</span>
                  <span class="apex-post-meta-author">{post.author}</span>
                </>
              ) : null}
            </div>
            <h2 class="apex-post-title">{post.title}</h2>
            {post.description ? (
              <p class="apex-post-description">{post.description}</p>
            ) : null}
            <span class="apex-post-read">
              Read post
              <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </section>
    )}
  </main>
</BaseLayout>
