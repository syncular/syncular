{
  "name": "@syncular/demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "build": "vite build",
    "preview": "bun scripts/dev.ts --preview",
    "codegen": "bun ../../packages/syncular/src/cli.ts generate --manifest-dir .",
    "codegen:check": "bun ../../packages/syncular/src/cli.ts generate --manifest-dir . --check",
    "tsgo": "tsgo --noEmit"
  },
  "dependencies": {
    "@syncular/client": "workspace:*",
    "@syncular/core": "workspace:*",
    "@syncular/server": "workspace:*",
    "@syncular/typegen": "workspace:*",
    "hono": "^4.12.15",
    "kysely": "*",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.14"
  }
}
