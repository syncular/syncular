{
  "name": "@syncular/demo-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun src/server/index.ts",
    "dev:cf": "wrangler dev --config wrangler.toml",
    "build": "bun build index.html --outdir=dist --minify",
    "deploy:cf": "bun run --cwd .. build && wrangler deploy",
    "deploy:cf:dry-run": "bun run --cwd .. build && wrangler deploy --dry-run",
    "generate:types": "node --import tsx scripts/generate-types.ts",
    "tsgo": "tsgo --noEmit"
  },
  "dependencies": {
    "@syncular/client": "workspace:*",
    "@syncular/client-plugin-encryption": "workspace:*",
    "@syncular/client-react": "workspace:*",
    "@syncular/core": "workspace:*",
    "@syncular/dialect-d1": "workspace:*",
    "@syncular/dialect-pglite": "workspace:*",
    "@syncular/dialect-wa-sqlite": "workspace:*",
    "@syncular/server": "workspace:*",
    "@syncular/server-cloudflare": "workspace:*",
    "@syncular/server-dialect-postgres": "workspace:*",
    "@syncular/server-dialect-sqlite": "workspace:*",
    "@syncular/server-hono": "workspace:*",
    "@syncular/transport-http": "workspace:*",
    "@syncular/transport-ws": "workspace:*",
    "@syncular/migrations": "workspace:*",
    "@syncular/ui": "workspace:*",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.159.5",
    "lucide-react": "^0.563.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "hono": "*",
    "kysely": "*",
    "@cloudflare/workers-types": "^4.20260207.0",
    "@syncular/typegen": "workspace:*",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4",
    "tsx": "^4",
    "wrangler": "^4.63.0"
  }
}
