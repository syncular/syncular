{
  "name": "syncular-docs",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "dev": "next dev --turbopack",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "tsgo": "tsgo --noEmit",
    "generate": "bun generate:schema && bun generate:openapi",
    "generate:schema": "bun --cwd ../../packages/server-hono generate:openapi",
    "generate:openapi": "bun scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.16.3",
    "@syncular/ui": "workspace:*",
    "fumadocs-core": "16.5.0",
    "fumadocs-mdx": "14.2.6",
    "fumadocs-openapi": "^10.3.1",
    "fumadocs-ui": "16.5.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@webgpu/types": "^0.1.69",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "wrangler": "^4.63.0"
  }
}
