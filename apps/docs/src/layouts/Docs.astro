---
// The docs shell: teletype sidebar + article column. Styling lives in
// public/style.css (shared with the landing page), not in scoped styles —
// the markdown body needs the global classes anyway.
//
// <ClientRouter> turns docs↔docs navigation into client-side swaps (no full
// reload, no white flash). The sidebar carries `transition:persist`, so the
// SAME element survives each swap — its scroll position is kept and it never
// re-renders. Links to pages without the router (the landing hero, 404) fall
// back to a normal full navigation automatically.
import { ClientRouter } from 'astro:transitions';
import PageMeta from '../components/PageMeta.astro';
import { nav } from '../nav';
import { DEFAULT_DESCRIPTION } from '../seo';
// package.json at the repository root is the one release-version authority.
import rootPkg from '../../../../package.json';

interface Props {
  title: string;
  active: string;
  description?: string;
  canonicalPath?: string;
  wide?: boolean;
}
const {
  title,
  active,
  description = DEFAULT_DESCRIPTION,
  canonicalPath = `/${active}/`,
  wide = false,
} = Astro.props;
const releasedVersion = rootPkg.version;
---

<!doctype html>
<html lang="en">
  <head>
    <PageMeta
      title={title}
      description={description}
      canonicalPath={canonicalPath}
    />
    <link rel="alternate" type="text/markdown" href={`/${active}.md`} />
    <link rel="api-catalog" href="/.well-known/api-catalog" />
    <link rel="stylesheet" href="/style.css" />
    <script src="/webmcp.js" defer></script>
    <ClientRouter />
  </head>
  <body>
    <nav class="sidebar" transition:persist="sidebar">
      <a class="brand" href="/">syncular</a>
      {
        nav.map((section) => (
          <div class="nav-section">
            <h4>{section.title}</h4>
            <ul>
              {section.items.map((item) => (
                <li>
                  <a
                    href={`/${item.slug}/`}
                    class={item.slug === active ? 'active' : undefined}
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
    <main class:list={{ 'wide-main': wide }}>
      <div class="release-banner" role="note">
        documentation for published release <code>v{releasedVersion}</code>
      </div>
      <article class:list={{ 'wide-article': wide }}>
        <slot />
      </article>
    </main>

    <script>
      // The sidebar is persisted across swaps. Two things need doing by hand:
      // (1) its server-rendered `.active` is frozen on the first page, so
      // re-derive it from the URL on every navigation; (2) re-inserting the
      // persisted node during a swap drops its scrollTop, so save it just
      // before the swap and restore it just after.
      let sidebarScroll = 0;
      const sidebar = () => document.querySelector('.sidebar');

      document.addEventListener('astro:before-swap', () => {
        sidebarScroll = sidebar()?.scrollTop ?? 0;
      });
      document.addEventListener('astro:after-swap', () => {
        const sb = sidebar();
        if (sb) sb.scrollTop = sidebarScroll;
      });
      document.addEventListener('astro:page-load', () => {
        const path = location.pathname;
        for (const a of document.querySelectorAll<HTMLAnchorElement>(
          '.sidebar .nav-section a',
        )) {
          a.classList.toggle('active', a.getAttribute('href') === path);
        }
      });
    </script>
  </body>
</html>
