{
  "name": "syncular",
  "version": "0.0.6",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260403.1",
    "knip": "6.3.0",
    "npm-check-updates": "^20.0.0",
    "turbo": "^2.9.3"
  },
  "overrides": {
    "wrangler": "^4.80.0",
    "@cloudflare/workers-types": "^4.20260403.1",
    "hono": "4.12.15",
    "@tootallnate/once": "3.0.1",
    "kysely": "0.28.15",
    "minimatch": "^10.2.5",
    "yaml": "^2.8.3",
    "tar": "^7.5.13",
    "rollup": "^4.60.1",
    "js-yaml": "^4.1.1",
    "@xmldom/xmldom": "^0.8.13",
    "node-forge": "^1.4.0",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^2.3.2",
    "lodash-es": "^4.18.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "zod": "4.3.6",
    "dompurify": "^3.4.1",
    "fast-xml-parser": "^5.7.2",
    "next": "^16.2.4",
    "postcss": "^8.5.12",
    "uuid": "^14.0.0",
    "vite": "^8.0.10"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "up": "bun up:external",
    "up:external": "bunx npm-check-updates --dep prod,dev,optional,overrides --interactive --workspaces --root --format group",
    "build": "bun build:packages",
    "build:packages": "turbo build --filter='./packages/*' --cache-dir=.turbo --concurrency=100% --force",
    "docs": "bun --cwd apps/docs dev",
    "docs:build": "bun --cwd apps/docs build",
    "mobile": "bun --cwd tests/expo-app start",
    "mobile:android": "bun --cwd tests/expo-app android",
    "mobile:ios": "bun --cwd tests/expo-app ios",
    "mobile:web": "bun --cwd tests/expo-app web",
    "check": "bun tsgo && bun lint && bun run knip && bun run bundle:check && bun run audit",
    "check:fix": "bun tsgo && bun lint:fix && bun run knip && bun run bundle:check && bun run audit",
    "audit": "bun audit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "knip": "knip && knip --production --no-exit-code",
    "release": "turbo release --filter='./packages/*' --filter='./plugins/*/*' --concurrency=1",
    "tsgo": "turbo tsgo --cache-dir=.turbo --concurrency=100% --parallel --force",
    "generate:openapi": "bun generate:openapi:schema && bun generate:openapi:types && bun generate:openapi:docs",
    "generate:openapi:schema": "bun --cwd packages/server-hono generate:openapi",
    "generate:openapi:types": "bun --cwd packages/transport-http generate-types",
    "generate:openapi:docs": "bun --cwd apps/docs generate:openapi",
    "bundle:check": "bun run scripts/check-client-bundle.ts",
    "sync:icons": "bun scripts/copy-app-icons.ts",
    "postinstall": "bun sync:icons && git config core.hooksPath .githooks 2>/dev/null || true",
    "test": "bun test packages tests/unit tests/integration tests/dialects tests/typegen",
    "test:coverage": "bun test --coverage packages tests/unit tests/integration tests/dialects tests/typegen",
    "test:watch": "bun test --watch packages tests/unit tests/integration tests/dialects tests/typegen",
    "test:integration": "bun --cwd tests/integration test",
    "test:integration:full": "MATRIX_FULL=true bun --cwd tests/integration test",
    "test:integration:load": "bun --cwd tests/integration test __tests__/load.test.ts",
    "test:load": "bun run test:integration:load",
    "test:load:server": "bun run --cwd tests/load server",
    "test:load:server:sqlite": "LOAD_DB_DIALECT=sqlite bun run --cwd tests/load server",
    "test:load:server:sqlite:large": "LOAD_DB_DIALECT=sqlite SEED_ROWS=1000000 SEED_USERS=1200 SEED_RANDOM_SEED=42 bun run --cwd tests/load server",
    "test:load:push-pull": "bun run --cwd tests/load k6:push-pull",
    "test:load:websocket": "bun run --cwd tests/load k6:websocket",
    "test:load:bootstrap": "bun run --cwd tests/load k6:bootstrap",
    "test:load:bootstrap-storm": "bun run --cwd tests/load k6:bootstrap-storm",
    "test:load:reconnect-storm": "bun run --cwd tests/load k6:reconnect-storm",
    "test:load:reconnect-soak": "bun run --cwd tests/load k6:reconnect-soak",
    "test:load:maintenance-churn": "bun run --cwd tests/load k6:maintenance-churn",
    "test:load:mixed": "bun run --cwd tests/load k6:mixed",
    "test:load:mixed-soak": "bun run --cwd tests/load k6:mixed-soak",
    "test:load:nightly": "bun --cwd tests/load nightly",
    "test:load:dashboard": "bun run --cwd tests/load k6:dashboard",
    "test:perf": "bun --cwd tests/perf test",
    "test:perf:stable": "bun --cwd tests/perf stable-ci",
    "test:perf:fetch-history": "bun --cwd tests/perf fetch-history",
    "test:perf:trend": "bun --cwd tests/perf trend-ci",
    "test:perf:update-baseline": "bun --cwd tests/perf update-baseline",
    "test:runtime": "bun --cwd tests/runtime test",
    "test:runtime:browser": "bun --cwd tests/runtime test:browser",
    "test:runtime:demo": "bun --cwd tests/runtime test:demo",
    "test:runtime:cloudflare": "bun --cwd tests/runtime test:cloudflare",
    "test:runtime:d1": "bun --cwd tests/runtime test:d1",
    "test:runtime:demo-latency": "bun --cwd tests/runtime measure:demo-latency",
    "test:runtime:demo-toggle-latency": "bun --cwd tests/runtime measure:demo-toggle-latency",
    "test:push": "bun test packages tests/unit tests/dialects tests/typegen && bun test tests/integration/__tests__/features.test.ts && bun run test:runtime:node",
    "test:all": "bun test && bun test:runtime && bun test:load && bun test:perf",
    "ci:cloudflare": "act -j runtime-cloudflare -W .github/workflows/checks.yml",
    "ci:test": "act -j test -W .github/workflows/checks.yml",
    "ci:browser": "act -j runtime-browser -W .github/workflows/checks.yml",
    "ci:d1": "act -j runtime-d1 -W .github/workflows/checks.yml",
    "ci:node": "act -j runtime-node -W .github/workflows/checks.yml",
    "ci:deno": "act -j runtime-deno -W .github/workflows/checks.yml",
    "ci:relay": "act -j runtime-relay -W .github/workflows/checks.yml",
    "ci:electron": "act -j runtime-electron -W .github/workflows/checks.yml",
    "ci:all": "act -j test -j runtime-browser -j runtime-d1 -j runtime-cloudflare -j runtime-node -j runtime-deno -j runtime-relay -j runtime-electron -W .github/workflows/checks.yml",
    "test:runtime:relay": "bun --cwd tests/runtime test:relay",
    "test:runtime:node": "bun --cwd tests/runtime test:node",
    "test:runtime:deno": "bun --cwd tests/runtime test:deno",
    "test:runtime:electron": "bun --cwd tests/runtime test:electron"
  },
  "workspaces": [
    "packages/*",
    "plugins/*/*",
    "apps/*",
    "config",
    "tests/*"
  ]
}
