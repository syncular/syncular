{
  "name": "syncular",
  "version": "0.0.6",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260403.1",
    "knip": "6.3.0",
    "npm-check-updates": "^20.0.0",
    "turbo": "^2.9.3"
  },
  "overrides": {
    "wrangler": "^4.80.0",
    "@cloudflare/workers-types": "^4.20260403.1",
    "hono": "4.12.15",
    "@tootallnate/once": "3.0.1",
    "kysely": "0.28.15",
    "minimatch": "^10.2.5",
    "yaml": "^2.8.3",
    "tar": "^7.5.13",
    "rollup": "^4.60.1",
    "js-yaml": "^4.1.1",
    "@xmldom/xmldom": "^0.8.13",
    "node-forge": "^1.4.0",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^2.3.2",
    "lodash-es": "^4.18.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "zod": "4.3.6",
    "dompurify": "^3.4.1",
    "fast-xml-parser": "^5.7.2",
    "next": "^16.2.4",
    "postcss": "^8.5.12",
    "uuid": "^14.0.0",
    "vite": "^8.0.10"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "up": "bun up:external",
    "up:external": "bunx npm-check-updates --dep prod,dev,optional,overrides --interactive --workspaces --root --format group",
    "build": "bun build:packages",
    "build:packages": "turbo build --filter='./packages/*' --cache-dir=.turbo --concurrency=100% --force",
    "build:rust": "turbo build --filter='./rust/bindings/*' --cache-dir=.turbo --concurrency=100% --force",
    "demo": "bun --cwd apps/demo dev",
    "docs": "bun --cwd apps/docs dev",
    "docs:build": "bun --cwd apps/docs build",
    "mobile": "bun --cwd tests/expo-app start",
    "mobile:android": "bun --cwd tests/expo-app android",
    "mobile:ios": "bun --cwd tests/expo-app ios",
    "mobile:web": "bun --cwd tests/expo-app web",
    "check": "bun tsgo && bun lint && bun run knip && bun run bundle:check && bun run audit",
    "check:fix": "bun tsgo && bun lint:fix && bun run knip && bun run bundle:check && bun run audit",
    "audit": "bun audit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "knip": "knip && knip --production --no-exit-code",
    "release": "turbo release --filter='./packages/*' --filter='./rust/bindings/*' --filter='./plugins/*/*' --concurrency=1",
    "tsgo": "turbo tsgo --cache-dir=.turbo --concurrency=100% --parallel --force",
    "generate:openapi": "bun generate:openapi:schema && bun generate:openapi:types && bun generate:openapi:docs",
    "generate:openapi:schema": "bun --cwd packages/server-hono generate:openapi",
    "generate:openapi:types": "bun --cwd packages/transport-http generate-types",
    "generate:openapi:docs": "bun --cwd apps/docs generate:openapi",
    "bundle:check": "bun run scripts/check-client-bundle.ts",
    "rust:fmt": "cargo fmt --manifest-path rust/Cargo.toml --all -- --check",
    "rust:test": "cargo test --manifest-path rust/Cargo.toml --workspace",
    "rust:check:no-default": "cargo check --manifest-path rust/Cargo.toml -p syncular-runtime --no-default-features",
    "rust:check:client-native-crdt": "cargo check --manifest-path rust/Cargo.toml -p syncular-client --no-default-features --features native,crdt-yjs",
    "rust:codegen:check": "cargo run --manifest-path rust/Cargo.toml -p syncular-codegen -- --manifest-dir rust/examples/todo-app --check",
    "client:test": "bun --cwd packages/client test",
    "client:tsgo": "bun --cwd packages/client tsgo",
    "client:test:wasm:variants": "bun --cwd packages/client test:wasm:variants",
    "client:build:wasm": "bun --cwd packages/client build:wasm",
    "client:build:wasm:core": "bun --cwd packages/client build:wasm:core",
    "client:build:wasm:variants": "bun --cwd packages/client build:wasm:variants",
    "client:catalog:wasm": "bun --cwd packages/client catalog:wasm",
    "client:size": "bun --cwd packages/client size:wasm:check",
    "client:size:core": "bun --cwd packages/client size:wasm:core",
    "client-crdt-adapters:test": "bun --cwd packages/client-crdt-adapters test",
    "client-crdt-adapters:tsgo": "bun --cwd packages/client-crdt-adapters tsgo",
    "client-crdt-adapters:build": "bun --cwd packages/client-crdt-adapters build",
    "rust:native-smoke": "bash rust/examples/todo-app/native-smokes/run-local.sh",
    "rust:native:package": "bash rust/scripts/package-native-bindings.sh --all",
    "rust:native:package:apple": "bash rust/scripts/package-native-bindings.sh --apple",
    "rust:native:package:android": "bash rust/scripts/package-native-bindings.sh --android",
    "rust:native:package:java": "bash rust/scripts/package-native-bindings.sh --java",
    "rust:native:package:java:linux": "bash rust/scripts/package-native-bindings.sh --java-linux-x86_64",
    "rust:native:package:java:windows": "bash rust/scripts/package-native-bindings.sh --java-windows-x86_64",
    "rust:native:lifecycle:ios": "bash rust/examples/todo-app/native-smokes/ios-lifecycle/run-local.sh",
    "rust:native:lifecycle:android": "bash rust/examples/todo-app/native-smokes/android-lifecycle/run-local.sh",
    "rust:native:lifecycle": "bun run rust:native:lifecycle:ios && bun run rust:native:lifecycle:android",
    "rust:native:release-check": "bun run rust:native:package:apple && bun run rust:native:package:android && bun run rust:native:package:java && bun run rust:native:package:java:linux && bun run rust:native-smoke",
    "rust:conformance:fast": "bash rust/scripts/run-conformance-gates.sh --fast",
    "rust:conformance": "bash rust/scripts/run-conformance-gates.sh --browser-hono",
    "rust:conformance:native": "bash rust/scripts/run-conformance-gates.sh --native",
    "rust:conformance:all": "bash rust/scripts/run-conformance-gates.sh --all",
    "rust:ci:native": "bun run rust:fmt && bun run rust:test && bun run rust:check:no-default && bun run rust:check:client-native-crdt && bun run rust:codegen:check",
    "rust:ci:browser": "bun run client:test && bun run client:tsgo && bun run client-crdt-adapters:test && bun run client-crdt-adapters:tsgo && bun run client-crdt-adapters:build && bun run client:build:wasm",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true",
    "test": "bun test packages tests/unit tests/dialects tests/typegen",
    "test:coverage": "bun test --coverage packages tests/unit tests/dialects tests/typegen",
    "test:watch": "bun test --watch packages tests/unit tests/dialects tests/typegen",
    "test:load:server": "bun run --cwd tests/load server",
    "test:load:server:sqlite": "LOAD_DB_DIALECT=sqlite bun run --cwd tests/load server",
    "test:load:server:sqlite:large": "LOAD_DB_DIALECT=sqlite SEED_ROWS=1000000 SEED_USERS=1200 SEED_RANDOM_SEED=42 bun run --cwd tests/load server",
    "test:load:push-pull": "bun run --cwd tests/load k6:push-pull",
    "test:load:websocket": "bun run --cwd tests/load k6:websocket",
    "test:load:bootstrap": "bun run --cwd tests/load k6:bootstrap",
    "test:load:bootstrap-storm": "bun run --cwd tests/load k6:bootstrap-storm",
    "test:load:reconnect-storm": "bun run --cwd tests/load k6:reconnect-storm",
    "test:load:reconnect-soak": "bun run --cwd tests/load k6:reconnect-soak",
    "test:load:maintenance-churn": "bun run --cwd tests/load k6:maintenance-churn",
    "test:load:mixed": "bun run --cwd tests/load k6:mixed",
    "test:load:mixed-soak": "bun run --cwd tests/load k6:mixed-soak",
    "test:load:nightly": "bun --cwd tests/load nightly",
    "test:load:dashboard": "bun run --cwd tests/load k6:dashboard",
    "test:push": "bun test packages tests/unit tests/dialects tests/typegen && bun run client:test",
    "test:all": "bun test && bun run client:test && bun run rust:conformance:fast"
  },
  "workspaces": [
    "packages/*",
    "rust/bindings/*",
    "rust/examples/*",
    "plugins/*/*",
    "apps/*",
    "config",
    "tests/*"
  ]
}
