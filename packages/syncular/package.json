{
  "name": "syncular",
  "version": "0.0.0",
  "description": "Offline-first sync framework for TypeScript",
  "license": "Apache-2.0",
  "author": "Benjamin Kniffler",
  "homepage": "https://syncular.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/syncular/syncular.git",
    "directory": "packages/syncular"
  },
  "bugs": {
    "url": "https://github.com/syncular/syncular/issues"
  },
  "keywords": [
    "sync",
    "offline-first",
    "realtime",
    "database",
    "typescript"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "syncular": "./dist/cli.js"
  },
  "scripts": {
    "tsgo": "tsgo --noEmit",
    "build": "rm -rf dist && tsgo && bun run build:cli",
    "build:cli": "bun build ./src/cli.ts --target=node --format=esm --outfile=./dist/cli.js",
    "release": "bun run build:cli && syncular-publish"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./client": {
      "bun": "./src/client.ts",
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    },
    "./react": {
      "bun": "./src/react.ts",
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      }
    },
    "./core": {
      "bun": "./src/core.ts",
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      }
    },
    "./console": {
      "bun": "./src/console.ts",
      "import": {
        "types": "./dist/console.d.ts",
        "default": "./dist/console.js"
      }
    },
    "./console/styles.css": "./src/console-styles.css",
    "./console/styles.source.css": "./src/console-styles.source.css",
    "./console-server": {
      "bun": "./src/console-server.ts",
      "import": {
        "types": "./dist/console-server.d.ts",
        "default": "./dist/console-server.js"
      }
    },
    "./ui": {
      "bun": "./src/ui.ts",
      "import": {
        "types": "./dist/ui.d.ts",
        "default": "./dist/ui.js"
      }
    },
    "./ui/observable-universe": {
      "bun": "./src/ui-observable-universe.ts",
      "import": {
        "types": "./dist/ui-observable-universe.d.ts",
        "default": "./dist/ui-observable-universe.js"
      }
    },
    "./ui/styles.css": "./src/ui-styles.css",
    "./server": {
      "bun": "./src/server.ts",
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      }
    },
    "./server-hono": {
      "bun": "./src/server-hono.ts",
      "import": {
        "types": "./dist/server-hono.d.ts",
        "default": "./dist/server-hono.js"
      }
    },
    "./server-service-worker": {
      "bun": "./src/server-service-worker.ts",
      "import": {
        "types": "./dist/server-service-worker.d.ts",
        "default": "./dist/server-service-worker.js"
      }
    },
    "./server-storage-filesystem": {
      "bun": "./src/server-storage-filesystem.ts",
      "import": {
        "types": "./dist/server-storage-filesystem.d.ts",
        "default": "./dist/server-storage-filesystem.js"
      }
    },
    "./server-storage-s3": {
      "bun": "./src/server-storage-s3.ts",
      "import": {
        "types": "./dist/server-storage-s3.d.ts",
        "default": "./dist/server-storage-s3.js"
      }
    },
    "./server-cloudflare": {
      "bun": "./src/server-cloudflare.ts",
      "import": {
        "types": "./dist/server-cloudflare.d.ts",
        "default": "./dist/server-cloudflare.js"
      }
    },
    "./server-dialect-sqlite": {
      "bun": "./src/server-dialect-sqlite.ts",
      "import": {
        "types": "./dist/server-dialect-sqlite.d.ts",
        "default": "./dist/server-dialect-sqlite.js"
      }
    },
    "./server-dialect-postgres": {
      "bun": "./src/server-dialect-postgres.ts",
      "import": {
        "types": "./dist/server-dialect-postgres.d.ts",
        "default": "./dist/server-dialect-postgres.js"
      }
    },
    "./transport-http": {
      "bun": "./src/transport-http.ts",
      "import": {
        "types": "./dist/transport-http.d.ts",
        "default": "./dist/transport-http.js"
      }
    },
    "./relay": {
      "bun": "./src/relay.ts",
      "import": {
        "types": "./dist/relay.d.ts",
        "default": "./dist/relay.js"
      }
    },
    "./migrations": {
      "bun": "./src/migrations.ts",
      "import": {
        "types": "./dist/migrations.d.ts",
        "default": "./dist/migrations.js"
      }
    },
    "./typegen": {
      "bun": "./src/typegen.ts",
      "import": {
        "types": "./dist/typegen.d.ts",
        "default": "./dist/typegen.js"
      }
    },
    "./server-plugin-yjs": {
      "bun": "./src/server-plugin-yjs.ts",
      "import": {
        "types": "./dist/server-plugin-yjs.d.ts",
        "default": "./dist/server-plugin-yjs.js"
      }
    },
    "./observability-sentry": {
      "bun": "./src/observability-sentry.ts",
      "import": {
        "types": "./dist/observability-sentry.d.ts",
        "default": "./dist/observability-sentry.js"
      }
    },
    "./dialects/better-sqlite3": {
      "bun": "./src/dialects/better-sqlite3.ts",
      "import": {
        "types": "./dist/dialects/better-sqlite3.d.ts",
        "default": "./dist/dialects/better-sqlite3.js"
      }
    },
    "./dialects/bun-sqlite": {
      "bun": "./src/dialects/bun-sqlite.ts",
      "import": {
        "types": "./dist/dialects/bun-sqlite.d.ts",
        "default": "./dist/dialects/bun-sqlite.js"
      }
    },
    "./dialects/d1": {
      "bun": "./src/dialects/d1.ts",
      "import": {
        "types": "./dist/dialects/d1.d.ts",
        "default": "./dist/dialects/d1.js"
      }
    },
    "./dialects/libsql": {
      "bun": "./src/dialects/libsql.ts",
      "import": {
        "types": "./dist/dialects/libsql.d.ts",
        "default": "./dist/dialects/libsql.js"
      }
    },
    "./dialects/neon": {
      "bun": "./src/dialects/neon.ts",
      "import": {
        "types": "./dist/dialects/neon.d.ts",
        "default": "./dist/dialects/neon.js"
      }
    },
    "./dialects/pglite": {
      "bun": "./src/dialects/pglite.ts",
      "import": {
        "types": "./dist/dialects/pglite.d.ts",
        "default": "./dist/dialects/pglite.js"
      }
    },
    "./dialects/sqlite3": {
      "bun": "./src/dialects/sqlite3.ts",
      "import": {
        "types": "./dist/dialects/sqlite3.d.ts",
        "default": "./dist/dialects/sqlite3.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/__tests__/**",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**",
    "!dist/client-plugin-*",
    "!dist/dialect-wa-sqlite.*",
    "!dist/encryption.*",
    "!dist/server-dialect-neon.*",
    "!dist/testkit.*",
    "!dist/transport-ws.*",
    "!dist/yjs.*",
    "!test/**",
    "!tests/**"
  ],
  "dependencies": {
    "@syncular/client": "workspace:*",
    "@syncular/console": "workspace:*",
    "@syncular/core": "workspace:*",
    "@syncular/dialects": "workspace:*",
    "@syncular/migrations": "workspace:*",
    "@syncular/observability-sentry": "workspace:*",
    "@syncular/react": "workspace:*",
    "@syncular/relay": "workspace:*",
    "@syncular/server": "workspace:*",
    "@syncular/server-cloudflare": "workspace:*",
    "@syncular/server-dialect-postgres": "workspace:*",
    "@syncular/server-dialect-sqlite": "workspace:*",
    "@syncular/server-hono": "workspace:*",
    "@syncular/server-plugin-yjs": "workspace:*",
    "@syncular/server-service-worker": "workspace:*",
    "@syncular/server-storage-filesystem": "workspace:*",
    "@syncular/server-storage-s3": "workspace:*",
    "@syncular/transport-http": "workspace:*",
    "@syncular/typegen": "workspace:*",
    "@syncular/ui": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "*",
    "@syncular/config": "workspace:*"
  }
}
