{
  "name": "syncular",
  "version": "0.1.2",
  "description": "Syncular CLI (`npx syncular generate`) for the @syncular/* packages",
  "license": "Apache-2.0",
  "author": "Benjamin Kniffler",
  "homepage": "https://syncular.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/syncular/syncular.git",
    "directory": "packages/syncular"
  },
  "bugs": {
    "url": "https://github.com/syncular/syncular/issues"
  },
  "keywords": [
    "sync",
    "offline-first",
    "realtime",
    "database",
    "typescript"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "syncular": "./dist/cli.js"
  },
  "scripts": {
    "tsgo": "tsgo --noEmit",
    "build": "rm -rf dist && bun run build:cli",
    "build:cli": "bun build ./src/cli.ts --target=node --format=esm --outfile=./dist/cli.js",
    "release": "bun run build:cli && syncular-publish"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@syncular/typegen": "workspace:*"
  },
  "devDependencies": {
    "@syncular/config": "workspace:*"
  }
}
