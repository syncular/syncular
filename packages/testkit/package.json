{
  "name": "@syncular/testkit",
  "version": "0.1.3",
  "description": "Testing fixtures and utilities for Syncular",
  "license": "Apache-2.0",
  "author": "Benjamin Kniffler",
  "homepage": "https://syncular.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/syncular/syncular.git",
    "directory": "packages/testkit"
  },
  "bugs": {
    "url": "https://github.com/syncular/syncular/issues"
  },
  "keywords": [
    "sync",
    "offline-first",
    "testing",
    "testkit",
    "typescript"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./client-bridge": {
      "bun": "./src/client-bridge.ts",
      "import": {
        "types": "./dist/client-bridge.d.ts",
        "default": "./dist/client-bridge.js"
      }
    },
    "./server": {
      "bun": "./src/server.ts",
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      }
    }
  },
  "scripts": {
    "test": "bun test --pass-with-no-tests",
    "tsgo": "tsgo --noEmit",
    "build": "tsgo",
    "release": "syncular-publish"
  },
  "dependencies": {
    "@syncular/core": "workspace:*"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@syncular/client": "workspace:*",
    "@syncular/server": "workspace:*",
    "hono": "^4.12.15",
    "kysely": "^0.28.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@syncular/client": "workspace:*",
    "@syncular/config": "workspace:*",
    "@syncular/server": "workspace:*",
    "hono": "^4.12.15",
    "kysely": "*"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/__tests__/**",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**",
    "!test/**",
    "!tests/**"
  ],
  "peerDependenciesMeta": {
    "@electric-sql/pglite": {
      "optional": true
    },
    "@syncular/client": {
      "optional": true
    },
    "@syncular/server": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "kysely": {
      "optional": true
    }
  }
}
