{
  "name": "@syncular/client-expo",
  "version": "0.0.0",
  "description": "Expo bridge client for the Syncular Rust runtime",
  "license": "Apache-2.0",
  "author": "Benjamin Kniffler",
  "homepage": "https://syncular.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/syncular/syncular.git",
    "directory": "packages/client-expo"
  },
  "bugs": {
    "url": "https://github.com/syncular/syncular/issues"
  },
  "keywords": [
    "sync",
    "offline-first",
    "expo",
    "react-native",
    "rust"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "test": "bun test src/*.test.ts",
    "tsgo": "tsgo --noEmit",
    "build": "tsgo",
    "release": "bunx syncular-publish"
  },
  "dependencies": {
    "@syncular/client-react-native": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "kysely": "^0.28.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "*"
  },
  "devDependencies": {
    "@syncular/config": "workspace:*",
    "@syncular/testkit": "workspace:*",
    "kysely": "*",
    "react": "*"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ]
}
