{
  "name": "@syncular/react",
  "version": "0.2.1",
  "description": "React hooks for Syncular offline-first sync",
  "license": "Apache-2.0",
  "author": "Benjamin Kniffler",
  "homepage": "https://syncular.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/syncular/syncular.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/syncular/syncular/issues"
  },
  "keywords": [
    "sync",
    "offline-first",
    "realtime",
    "database",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "browser": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./typed": {
      "bun": "./src/typed.ts",
      "browser": "./src/typed.ts",
      "import": {
        "types": "./dist/typed.d.ts",
        "default": "./dist/typed.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "scripts": {
    "test": "bun test --preload ./test/setup.ts"
  },
  "dependencies": {
    "@syncular/client": "workspace:*"
  },
  "peerDependencies": {
    "@syncular/kysely": "workspace:*",
    "kysely": ">=0.27.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@syncular/kysely": {
      "optional": true
    },
    "kysely": {
      "optional": true
    }
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^15.11.0",
    "@syncular/core": "workspace:*",
    "@syncular/kysely": "workspace:*",
    "@syncular/server": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "kysely": "^0.29.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
