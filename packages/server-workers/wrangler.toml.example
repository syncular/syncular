# Example wrangler config for a Syncular v2 Workers deployment (TODO §4.2).
# Copy to `wrangler.toml` in your Worker project and fill in the ids.
#
# This deploys BOTH bindings (SPEC §1.1): the HTTP handler (POST /sync,
# GET /segments/:id, PUT/GET /blobs/:id) and realtime (§8) over a Durable
# Object (GET /realtime). For an HTTP-only deployment, omit the
# `[[durable_objects.bindings]]` + `[[migrations]]` blocks and drop the
# `realtime` option from `createWorkersFetchHandler` — still fully conformant
# (clients sync over POST /sync). See packages/server-workers/README.md.

name = "syncular-sync"
main = "src/worker.ts"
compatibility_date = "2024-09-23"

# --- D1: the server storage (D1ServerStorage) ------------------------------
# Create with: wrangler d1 create syncular
# Then apply the schema (see README): wrangler d1 migrations apply syncular
#
# The DO holds the SAME D1 binding, so realtime rounds and POST /sync rounds
# share one commit log and one segment store (no LISTEN/NOTIFY needed — the
# partition's sockets and its writes are co-located in its DO).
[[d1_databases]]
binding = "DB"                       # env.DB -> D1ServerStorage
database_name = "syncular"
database_id = "00000000-0000-0000-0000-000000000000"

# --- R2: durable segment + blob bytes (optional) ---------------------------
# R2 speaks the S3 API, so segments/blobs use S3SegmentStore + s3PresignedUrls
# (§5.4 delegated presign). The bucket binding is available as env.BUCKET if
# you prefer the native R2 binding for a custom store; the reference wiring
# uses the S3-compatible endpoint + an R2 access key (secrets below).
[[r2_buckets]]
binding = "BUCKET"
bucket_name = "syncular-segments"

# --- Secrets (set with `wrangler secret put NAME`) -------------------------
# R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY  -> S3SegmentStore
# SYNC_HMAC_KEY                                          -> native signed URLs (§5.4)
# plus whatever your authenticate() needs (JWT secret, etc.)

# --- Realtime (§8): the Durable Object host --------------------------------
# One SyncularRealtimeDO instance per partition (idFromName(partition)) hosts
# the RealtimeHub, WebSocket hibernation drives the existing RealtimeSession,
# and commit fan-out runs in-DO. The DO binding is available as env.REALTIME.
[[durable_objects.bindings]]
name = "REALTIME"
class_name = "SyncularRealtimeDO"

# The DO class is stateless across deploys (no SQLite storage of its own — all
# durable state lives in D1), so a plain new_classes migration is sufficient.
[[migrations]]
tag = "v1"
new_classes = ["SyncularRealtimeDO"]
