  "type": "module",
  "scripts": {
    "verify:node": "bun build ./test/node-database/verify-node.mjs --target=node --external better-sqlite3 --outfile=./.verify-node.built.mjs && node ./.verify-node.built.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./bun": "./src/bun-database.ts",
