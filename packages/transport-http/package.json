{
  "name": "@syncular/transport-http",
  "version": "0.0.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "tsgo": "tsgo --noEmit",
    "generate-types": "openapi-typescript ../server-hono/openapi.json -o src/generated/api.ts",
    "build": "rm -rf dist && tsgo"
  },
  "dependencies": {
    "@syncular/core": "workspace:*",
    "openapi-fetch": "^0.15.0"
  },
  "devDependencies": {
    "@syncular/config": "workspace:*",
    "openapi-typescript": "^7.10.1"
  },
  "files": [
    "dist",
    "src"
  ]
}
