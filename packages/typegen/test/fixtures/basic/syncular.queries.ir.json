      "sql": "select id, title, done, priority, estimated_at AS estimatedAt from tasks\n    where (tasks.project_id = :projectId)\n      and case when :__syqlActive0 = 0 then 1 else ( (\n  title like '%' || :needle || '%'\n) ) end\n      and case when :__syqlActive1 = 0 then 1 else ( priority >= :minPriority ) end\n      and case when :__syqlActive2 = 0 then 1 else ( done = 0 ) end order by priority desc, id desc limit min(coalesce(:__syqlPageSize, 50), 200)",
