{
  "manifestVersion": 1,
  "migrations": "./migrations",
  "output": {
    "ir": "./syncular.ir.json",
    "module": "./syncular.generated.ts",
    "queryIr": "./syncular.queries.ir.json",
    "queries": "./syncular.queries.ts",
    "swift": {
      "path": "./Syncular.generated.swift",
      "enumName": "BasicSchema",
      "queriesPath": "./Syncular.queries.swift"
    },
    "kotlin": {
      "path": "./Syncular.generated.kt",
      "package": "dev.syncular.basic",
      "objectName": "BasicSchema",
      "queriesPath": "./Syncular.queries.kt"
    },
    "dart": {
      "path": "./syncular.generated.dart",
      "queriesPath": "./syncular.queries.dart"
    },
    "rust": {
      "queriesPath": "./syncular.queries.rs"
    }
  },
  "schemaVersions": [
    { "version": 1, "through": "0001_initial" },
    { "version": 2, "through": "0002_add_task_estimate" },
    { "version": 3, "through": "0003_add_doc_crdt" },
    { "version": 4, "through": "0004_add_doc_blob_ref" }
  ],
  "tables": [
    { "name": "tasks", "scopes": ["project:{project_id}"] },
    {
      "name": "docs",
      "scopes": [
        "org:{org_id}",
        { "pattern": "project:{projectId}", "column": "project_id" }
      ]
    }
  ],
  "subscriptions": [
    {
      "name": "projectTasks",
      "table": "tasks",
      "scopes": { "project_id": ["{projectId}"] }
    },
    {
      "name": "acmeDocs",
      "table": "docs",
      "scopes": { "org_id": ["acme"], "projectId": ["{projectId}"] }
    }
  ]
}
