{
  "name": "@syncular/client-crdt-adapters",
  "version": "0.0.0",
  "description": "Rich-editor CRDT adapters for the Syncular client",
  "license": "Apache-2.0",
  "author": "Benjamin Kniffler",
  "homepage": "https://syncular.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/syncular/syncular.git",
    "directory": "packages/client-crdt-adapters"
  },
  "bugs": {
    "url": "https://github.com/syncular/syncular/issues"
  },
  "keywords": [
    "sync",
    "offline-first",
    "crdt",
    "yjs",
    "prosemirror",
    "tiptap"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "test": "bun test src/*.test.ts",
    "tsgo": "tsgo --noEmit",
    "build": "rm -rf dist && tsgo",
    "release": "syncular-publish"
  },
  "peerDependencies": {
    "@syncular/client": ">=0.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@syncular/config": "workspace:*",
    "yjs": "^13.6.30"
  },
  "files": [
    "dist",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/__tests__/**",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**",
    "!test/**",
    "!tests/**"
  ]
}
