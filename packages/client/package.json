{
  "name": "@syncular/client",
  "version": "0.0.0",
  "description": "Syncular Rust-owned SQLite browser client",
  "license": "Apache-2.0",
  "author": "Benjamin Kniffler",
  "homepage": "https://syncular.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/syncular/syncular.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/syncular/syncular/issues"
  },
  "keywords": [
    "sync",
    "offline-first",
    "database",
    "typescript",
    "rust",
    "wasm",
    "sqlite",
    "kysely"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "browser": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./worker": {
      "bun": "./src/worker-entry.ts",
      "browser": "./src/worker-entry.ts",
      "import": {
        "types": "./dist/worker-entry.d.ts",
        "default": "./dist/worker-entry.js"
      }
    }
  },
  "scripts": {
    "generate:bridge": "bun scripts/generate-bridge.ts",
    "test": "bun test src/*.test.ts",
    "test:wasm:auth": "bun --cwd ../../rust/bindings/javascript build:wasm:dev && bun test src/__tests__/auth-hono.wasm.test.ts",
    "test:wasm:hono": "bun --cwd ../../rust/bindings/javascript build:wasm:dev && bun test src/__tests__/*-hono.wasm.test.ts",
    "test:wasm:variants": "bun --cwd ../../rust/bindings/javascript build:wasm:core && bun test src/__tests__/variant-core.wasm.test.ts",
    "tsgo": "tsgo --noEmit",
    "build": "tsgo",
    "release": "syncular-publish"
  },
  "dependencies": {
    "@syncular/client-javascript-bindings": "workspace:*",
    "@syncular/core": "workspace:*",
    "kysely": "^0.28.0",
    "kysely-generic-sqlite": "^1.2.1"
  },
  "devDependencies": {
    "@syncular/config": "workspace:*",
    "@syncular/dialects": "workspace:*",
    "hono": "^4.12.15"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/__tests__/**",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**",
    "!test/**",
    "!tests/**"
  ]
}
