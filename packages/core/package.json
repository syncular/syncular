{
  "name": "@syncular/core",
  "version": "0.1.3",
  "description": "Core protocol types and shared utilities for the Syncular sync framework",
  "license": "Apache-2.0",
  "author": "Benjamin Kniffler",
  "homepage": "https://syncular.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/syncular/syncular.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/syncular/syncular/issues"
  },
  "keywords": [
    "sync",
    "offline-first",
    "realtime",
    "database",
    "typescript"
  ],
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "browser": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./http": {
      "bun": "./src/http/index.ts",
      "browser": "./src/http/index.ts",
      "import": {
        "types": "./dist/http/index.d.ts",
        "default": "./dist/http/index.js"
      }
    },
    "./http/blob": {
      "bun": "./src/http/blob.ts",
      "browser": "./src/http/blob.ts",
      "import": {
        "types": "./dist/http/blob.d.ts",
        "default": "./dist/http/blob.js"
      }
    },
    "./sentry": {
      "bun": "./src/sentry.ts",
      "browser": "./src/sentry.ts",
      "import": {
        "types": "./dist/sentry.d.ts",
        "default": "./dist/sentry.js"
      }
    }
  },
  "scripts": {
    "fixtures:protocol": "bun scripts/generate-protocol-fixtures.ts",
    "test": "bun test src/__tests__",
    "tsgo": "tsgo --noEmit",
    "build": "tsgo",
    "release": "syncular-publish",
    "generate:http-types": "openapi-typescript ../server/openapi.json -o src/http/generated/api.ts"
  },
  "peerDependencies": {
    "kysely": "^0.28.0",
    "zod": "^4.0.0",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@syncular/config": "workspace:*",
    "kysely": "*",
    "zod": "*",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/__tests__/**",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**",
    "!test/**",
    "!tests/**"
  ],
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "peerDependenciesMeta": {
    "openapi-fetch": {
      "optional": true
    }
  }
}
