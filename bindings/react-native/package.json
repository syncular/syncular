{
  "name": "@syncular/react-native",
  "version": "0.0.0",
  "private": true,
  "description": "React Native module for syncular v2 — the native Rust core (FFI) surfaced as the SyncClientLike interface, so @syncular/react hooks work unchanged in RN.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "ios",
    "android",
    "cpp",
    "syncular-react-native.podspec",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "dependencies": {
    "@syncular/client": "workspace:*"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.0",
    "@syncular/react": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "codegenConfig": {
    "name": "SyncularSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.syncular"
    }
  }
}
