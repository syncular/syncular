{
  "name": "@syncular/example-todo-rust",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen:config": "bun ../../../packages/typegen/src/cli.ts codegen-config --app ./syncular.app.ts --out ./syncular.codegen.json",
    "codegen": "bun ../../../packages/typegen/src/cli.ts codegen-config --app ./syncular.app.ts --out ./syncular.codegen.json && cargo run --manifest-path ../../Cargo.toml -p syncular-codegen -- --manifest-dir .",
    "codegen:check": "bun ../../../packages/typegen/src/cli.ts codegen-config --app ./syncular.app.ts --out ./syncular.codegen.json --check && cargo run --manifest-path ../../Cargo.toml -p syncular-codegen -- --manifest-dir . --check"
  },
  "dependencies": {
    "@syncular/client": "workspace:*",
    "@syncular/core": "workspace:*",
    "@syncular/server": "workspace:*",
    "@syncular/typegen": "workspace:*",
    "hono": "^4.12.15",
    "kysely": "^0.28.0"
  }
}
