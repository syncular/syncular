{
  "name": "@syncular/example-todo-rust",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen:config": "bun ./syncular.codegen.ts",
    "codegen": "bun ./syncular.codegen.ts && cargo run --manifest-path ../../Cargo.toml -p syncular-codegen -- --manifest-dir .",
    "codegen:check": "bun test ./syncular.app.test.ts && cargo run --manifest-path ../../Cargo.toml -p syncular-codegen -- --manifest-dir . --check"
  },
  "dependencies": {
    "@syncular/client": "workspace:*",
    "@syncular/core": "workspace:*",
    "@syncular/server": "workspace:*",
    "@syncular/typegen": "workspace:*",
    "hono": "^4.12.15",
    "kysely": "^0.28.0"
  }
}
