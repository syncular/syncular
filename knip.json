{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "includeEntryExports": true,
  "ignoreExportsUsedInFile": false,
  "bun": true,
  "expo": true,
  "postcss": true,
  "storybook": true,
  "tailwind": true,
  "playwright": true,
  "typescript": true,
  "ignore": [
    ".context/**",
    "**/generated/**",
    "types/**"
  ],
  "ignoreDependencies": [
    "happy-dom",
    "tailwindcss"
  ],
  "ignoreBinaries": [
    "act",
    "k6",
    "maestro",
    "version"
  ],
  "ignoreIssues": {
    "plugins/blob/server-storage-filesystem/src/index.ts": [
      "types"
    ],
    "plugins/blob/server-storage-s3/src/index.ts": [
      "types"
    ],
    "packages/server-hono/src/websocket-origin.ts": [
      "exports"
    ],
    "config/tsconfig.react-native.json": [
      "unlisted"
    ],
    "packages/core/src/snapshot-chunks.ts": [
      "duplicates"
    ],
    "packages/server-hono/src/validation.ts": [
      "exports"
    ],
    "packages/client/src/client.ts": [
      "duplicates"
    ],
    "packages/client/src/database.ts": [
      "duplicates"
    ],
    "packages/client/src/diagnostics.ts": [
      "exports"
    ],
    "packages/client/src/sql-safety.ts": [
      "exports"
    ],
    "packages/client/src/worker-protocol.ts": [
      "types"
    ],
    "packages/client/src/worker-realtime.ts": [
      "types"
    ],
    "packages/client-crdt-adapters/src/webview-host-facade.ts": [
      "exports"
    ],
    "packages/client-crdt-adapters/src/yjs-document-field-adapter.ts": [
      "exports"
    ]
  },
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.ts"
      ]
    },
    "packages/core": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts"
      ]
    },
    "plugins/yjs/server": {
      "includeEntryExports": false
    },
    "plugins/blob/server-storage-filesystem": {
      "includeEntryExports": false
    },
    "plugins/blob/server-storage-s3": {
      "includeEntryExports": false
    },
    "packages/console": {
      "includeEntryExports": false
    },
    "packages/server": {
      "includeEntryExports": false
    },
    "packages/server-hono": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts",
        "scripts/*.ts"
      ]
    },
    "packages/server-cloudflare": {
      "includeEntryExports": false
    },
    "packages/server-dialect-sqlite": {
      "includeEntryExports": false
    },
    "packages/server-dialect-postgres": {
      "includeEntryExports": false
    },
    "packages/server-service-worker": {
      "includeEntryExports": false
    },
    "packages/server-storage-filesystem": {
      "includeEntryExports": false
    },
    "packages/server-storage-s3": {
      "includeEntryExports": false
    },
    "packages/transport-http": {
      "includeEntryExports": false
    },
    "packages/transport-ws": {
      "includeEntryExports": false
    },
    "packages/relay": {
      "includeEntryExports": false
    },
    "packages/migrations": {
      "includeEntryExports": false
    },
    "packages/typegen": {
      "includeEntryExports": false
    },
    "packages/testkit": {
      "includeEntryExports": false
    },
    "packages/client-expo": {
      "includeEntryExports": false
    },
    "packages/client-react": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts"
      ]
    },
    "packages/client-react-native": {
      "includeEntryExports": false
    },
    "packages/client-tauri": {
      "includeEntryExports": false
    },
    "packages/client": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts",
        "src/**/__tests__/**/*.ts",
        "scripts/*.ts"
      ]
    },
    "packages/client-crdt-adapters": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts"
      ]
    },
    "packages/syncular": {
      "includeEntryExports": false
    },
    "packages/observability-sentry": {
      "includeEntryExports": false
    },
    "packages/dialect-bun-sqlite": {
      "includeEntryExports": false
    },
    "packages/dialect-better-sqlite3": {
      "includeEntryExports": false
    },
    "packages/dialect-pglite": {
      "includeEntryExports": false
    },
    "packages/dialect-sqlite3": {
      "includeEntryExports": false
    },
    "packages/dialect-neon": {
      "includeEntryExports": false
    },
    "packages/dialect-libsql": {
      "includeEntryExports": false
    },
    "packages/dialect-d1": {
      "includeEntryExports": false
    },
    "packages/dialect-wa-sqlite": {
      "includeEntryExports": false
    },
    "packages/dialect-expo-sqlite": {
      "includeEntryExports": false
    },
    "packages/dialect-react-native-nitro-sqlite": {
      "includeEntryExports": false
    },
    "packages/dialect-electron-sqlite": {
      "includeEntryExports": false
    },
    "rust/bindings/javascript": {
      "includeEntryExports": false,
      "entry": [
        "scripts/*.ts"
      ]
    },
    "rust/examples/todo-app": {
      "includeEntryExports": false,
      "entry": [
        "conformance/**/*.ts",
        "native-smokes/**/*.ts"
      ],
      "ignoreDependencies": [
        "@syncular/client"
      ]
    },
    "packages/ui": {
      "includeEntryExports": false
    },
    "apps/console": {
      "entry": [
        "src/main.tsx!"
      ]
    },
    "apps/docs": {
      "includeEntryExports": false,
      "entry": [
        "source.config.ts",
        "open-next.config.ts",
        "scripts/*.ts"
      ]
    },
    "tests/unit": {
      "entry": [
        "**/*.test.ts"
      ]
    },
    "tests/dialects": {
      "includeEntryExports": false,
      "entry": [
        "**/*.ts"
      ]
    },
    "tests/load": {
      "includeEntryExports": false,
      "entry": [
        "lib/*.js",
        "scripts/*.js",
        "*.ts"
      ],
      "ignoreDependencies": [
        "k6"
      ]
    },
    "tests/typegen": {
      "includeEntryExports": false,
      "entry": [
        "**/*.ts"
      ]
    },
    "tests/expo-app": {
      "entry": [
        "**/*.ts",
        "**/*.tsx"
      ]
    }
  }
}
