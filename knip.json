{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "includeEntryExports": true,
  "ignoreExportsUsedInFile": false,
  "bun": true,
  "expo": true,
  "postcss": true,
  "storybook": true,
  "tailwind": true,
  "playwright": true,
  "typescript": true,
  "ignore": [
    ".claude/**",
    "**/generated/**",
    "types/**",
    ".source/**",
    ".next/**",
    "**/dist/**"
  ],
  "ignoreDependencies": [
    "@syncular/config",
    "happy-dom",
    "tailwindcss",
    "wrangler"
  ],
  "ignoreBinaries": ["k6", "maestro"],
  "workspaces": {
    "packages/core": {
      "entry": [
        "src/**/*.test.ts"
      ]
    },
    "packages/client-react": {
      "entry": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx"
      ]
    },
    "packages/server-hono": {
      "entry": [
        "src/**/*.test.ts"
      ]
    },
    "apps/demo": {
      "entry": [
        "src/main.tsx!",
        "src/server/server.ts!",
        "src/cf/index.ts!",
        "scripts/*.ts"
      ]
    },
    "apps/console": {
      "entry": [
        "src/main.tsx!"
      ]
    },
    "tests/shared": {
      "entry": ["**/*.ts"]
    },
    "tests/unit": {
      "entry": ["**/*.test.ts"]
    },
    "tests/dialects": {
      "entry": ["**/*.ts"]
    },
    "tests/perf": {
      "entry": ["**/*.ts"]
    },
    "tests/load": {
      "entry": ["lib/*.js", "scripts/*.js"],
      "ignoreDependencies": ["k6"]
    },
    "tests/integration": {
      "entry": ["**/*.ts"]
    },
    "tests/runtime": {
      "entry": ["**/*.ts"]
    },
    "tests/expo-app": {
      "entry": ["**/*.ts", "**/*.tsx"]
    },
    "apps/docs": {
      "entry": [
        "source.config.ts",
        "open-next.config.ts",
        "scripts/*.ts"
      ]
    }
  }
}
