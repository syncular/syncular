{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "includeEntryExports": true,
  "ignoreExportsUsedInFile": false,
  "bun": true,
  "postcss": true,
  "storybook": true,
  "tailwind": true,
  "playwright": true,
  "typescript": true,
  "ignore": [
    "**/generated/**",
    "types/**",
    "packages/create-syncular-app/template/**"
  ],
  "ignoreDependencies": [
    "tailwindcss"
  ],
  "ignoreBinaries": [
    "k6",
    "tar",
    "version"
  ],
  "ignoreIssues": {
    "plugins/blob/server-storage-filesystem/src/index.ts": [
      "types"
    ],
    "plugins/blob/server-storage-s3/src/index.ts": [
      "types"
    ],
    "apps/console/build.ts": [
      "files"
    ],
    "apps/demo/scripts/dev.ts": [
      "files"
    ],
    "apps/demo/src/server/sync-server.ts": [
      "files"
    ],
    "apps/apex/package.json": [
      "dependencies"
    ],
    "apps/demo/package.json": [
      "dependencies"
    ],
    "packages/console/build-static.ts": [
      "files"
    ],
    "rust/examples/todo-app/package.json": [
      "dependencies"
    ],
    "packages/server-hono/src/websocket-origin.ts": [
      "exports"
    ],
    "config/tsconfig.react-native.json": [
      "unlisted"
    ],
    "packages/core/src/snapshot-chunks.ts": [
      "duplicates"
    ],
    "packages/server-hono/src/validation.ts": [
      "exports"
    ],
    "packages/client/src/client.ts": [
      "duplicates"
    ],
    "packages/client/src/database.ts": [
      "duplicates"
    ],
    "packages/client/src/diagnostics.ts": [
      "exports"
    ],
    "packages/client/src/sql-safety.ts": [
      "exports"
    ],
    "packages/client/src/worker-protocol.ts": [
      "types"
    ],
    "packages/client/src/worker-realtime.ts": [
      "types",
      "exports"
    ],
    "packages/client/src/generated-bridge.ts": [
      "types"
    ],
    "packages/client-crdt-adapters/src/webview-host-facade.ts": [
      "exports"
    ],
    "packages/client-crdt-adapters/src/yjs-document-field-adapter.ts": [
      "exports"
    ],
    "packages/react/src/__tests__/happy-dom.ts": [
      "files"
    ],
    "packages/console/src/lib/types.ts": [
      "types"
    ]
  },
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.ts"
      ]
    },
    "packages/core": {
      "includeEntryExports": false,
      "entry": [
        "scripts/*.ts",
        "src/**/*.test.ts"
      ]
    },
    "plugins/yjs/server": {
      "includeEntryExports": false
    },
    "plugins/blob/server-storage-filesystem": {
      "includeEntryExports": false
    },
    "plugins/blob/server-storage-s3": {
      "includeEntryExports": false
    },
    "packages/console": {
      "includeEntryExports": false
    },
    "packages/server": {
      "includeEntryExports": false
    },
    "packages/server-hono": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts",
        "scripts/*.ts"
      ]
    },
    "packages/server-cloudflare": {
      "includeEntryExports": false
    },
    "packages/server-dialect-sqlite": {
      "includeEntryExports": false
    },
    "packages/server-dialect-postgres": {
      "includeEntryExports": false
    },
    "packages/server-service-worker": {
      "includeEntryExports": false
    },
    "packages/server-storage-filesystem": {
      "includeEntryExports": false
    },
    "packages/server-storage-s3": {
      "includeEntryExports": false
    },
    "packages/transport-http": {
      "includeEntryExports": false
    },
    "packages/relay": {
      "includeEntryExports": false,
      "entry": [
        "scripts/*.ts",
        "src/evaluation/*.ts"
      ]
    },
    "packages/migrations": {
      "includeEntryExports": false
    },
    "packages/typegen": {
      "includeEntryExports": false
    },
    "packages/testkit": {
      "includeEntryExports": false
    },
    "packages/client-expo": {
      "includeEntryExports": false
    },
    "packages/react": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts"
      ]
    },
    "packages/client-react-native": {
      "includeEntryExports": false
    },
    "packages/client-tauri": {
      "includeEntryExports": false
    },
    "packages/client": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts",
        "src/**/__tests__/**/*.ts",
        "scripts/*.ts"
      ]
    },
    "packages/client-crdt-adapters": {
      "includeEntryExports": false,
      "entry": [
        "src/**/*.test.ts"
      ]
    },
    "packages/syncular": {
      "includeEntryExports": false,
      "ignoreDependencies": ["@syncular/typegen"]
    },
    "packages/create-syncular-app": {
      "includeEntryExports": false,
      "entry": [
        "src/cli.ts",
        "scripts/*.ts"
      ]
    },
    "packages/observability-sentry": {
      "includeEntryExports": false
    },
    "packages/dialects": {
      "includeEntryExports": false
    },
    "rust/bindings/javascript": {
      "includeEntryExports": false,
      "entry": [
        "scripts/*.ts"
      ]
    },
    "rust/examples/todo-app": {
      "includeEntryExports": false,
      "entry": [
        "server-handlers.ts",
        "syncular.app.ts",
        "conformance/**/*.ts",
        "native-smokes/**/*.ts"
      ]
    },
    "packages/ui": {
      "includeEntryExports": false
    },
    "apps/console": {
      "entry": [
        "src/main.tsx!"
      ]
    },
    "apps/demo": {
      "includeEntryExports": false,
      "entry": [
        "src/server/sync-server.ts",
        "syncular.app.ts"
      ]
    },
    "apps/apex": {
      "includeEntryExports": false,
      "entry": [
        "src/pages/**/*.astro",
        "src/layouts/**/*.astro"
      ]
    },
    "apps/docs": {
      "includeEntryExports": false,
      "entry": [
        "source.config.ts",
        "open-next.config.ts",
        "scripts/*.ts"
      ]
    },
    "tests/unit": {
      "entry": [
        "**/*.test.ts"
      ]
    },
    "tests/dialects": {
      "includeEntryExports": false,
      "entry": [
        "**/*.ts"
      ]
    },
    "tests/load": {
      "includeEntryExports": false,
      "entry": [
        "lib/*.js",
        "scripts/*.js",
        "*.ts"
      ],
      "ignoreDependencies": [
        "k6"
      ]
    },
    "tests/typegen": {
      "includeEntryExports": false,
      "entry": [
        "**/*.ts"
      ]
    }
  }
}
